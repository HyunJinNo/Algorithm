const input = require("fs").readFileSync("/dev/stdin").toString().split("\n");
const N = Number(input[0]); // 문제의 개수, 1 <= N <= 100
const arr = new Int8Array(input[1].split(" ").map(Number));
let answer = 0;
let count = 0;

for (let i = 0; i < N; i++) {
	if (arr[i] === 1) {
		count++;
		answer += count;
	} else {
		count = 0;
	}
}

console.log(answer);