const input = require("fs").readFileSync("/dev/stdin").toString();
const [X, Y] = input.split(" ").map(Number);

if (X === 0 || Y === 0) {
	console.log(0);
} else if (X > 0 && Y > 0) {
	console.log(1);
} else if (X < 0 && Y > 0) {
	console.log(2);
} else if (X < 0 && Y < 0) {
	console.log(3);
} else {
	console.log(4);
}